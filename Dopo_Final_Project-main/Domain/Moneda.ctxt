comment2.target=boolean\ isRecogida()
comment2.text=\r\n\ Indica\ si\ la\ moneda\ ya\ fue\ recogida.\r\n\r\n\ @return\ true\ cuando\ ya\ no\ esta\ disponible\ en\ el\ nivel.\r\n
comment3.params=
comment3.target=void\ reiniciar()
comment3.text=\r\n\ Restablece\ la\ moneda\ a\ su\ estado\ inicial.\r\n
